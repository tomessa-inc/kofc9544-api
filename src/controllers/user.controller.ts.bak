    public static apiUserInfo = defineEventHandler(async (event) =>  {
        const token = await userMapper.getAuthToken(event)
        const user = (await userMapper.getUserByToken(token))[0];

        return event.res.status(200).json({
            "code": 0,
            "data": user,
            "error": null,
            "message": "ok"
        });
    })

